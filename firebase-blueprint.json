{
  "entities": {
    "ContactInquiry": {
      "title": "Contact Inquiry",
      "description": "A message submitted via the contact form",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the guest"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Email of the guest"
        },
        "subject": {
          "type": "string",
          "description": "Subject of inquiry"
        },
        "message": {
          "type": "string",
          "description": "The inquiry message"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of submission"
        }
      },
      "required": ["name", "email", "subject", "message", "createdAt"]
    }
  },
  "firestore": {
    "contactInquiries/{inquiryId}": {
      "schema": "ContactInquiry",
      "description": "Collection of contact form submissions"
    }
  }
}
